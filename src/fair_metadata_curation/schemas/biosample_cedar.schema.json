{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/fair-metadata-curation/biosample_cedar.schema.json",
  "title": "BioSampleCEDARNormalizedRecord",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "geo_accession": {"type": ["string", "null"]},
    "gsm_accession": {"type": ["string", "null"]},
    "title": {"type": ["string", "null"]},
    "summary": {"type": ["string", "null"]},
    "organism": {"type": ["string", "null"]},
    "organism_term": {"$ref": "#/$defs/ontologyTermOrNull"},
    "age": {"type": ["string", "null"]},
    "biomaterial_provider": {"type": ["string", "null"]},
    "sex": {"type": ["string", "null"]},
    "tissue": {"type": ["string", "null"]},
    "tissue_term": {"$ref": "#/$defs/ontologyTermOrNull"},
    "cell_type": {"type": ["string", "null"]},
    "cell_type_term": {"$ref": "#/$defs/ontologyTermOrNull"},
    "cell_line": {"type": ["string", "null"]},
    "design": {"type": ["string", "null"]},
    "disease": {"type": ["string", "null"]},
    "disease_term": {"$ref": "#/$defs/ontologyTermOrNull"},
    "treatment": {"type": ["string", "null"]},
    "treatment_term": {"$ref": "#/$defs/ontologyTermOrNull"},
    "description": {"type": ["string", "null"]},
    "unmapped_fields": {
      "type": ["object", "null"],
      "additionalProperties": {"type": ["string", "number", "boolean", "array", "object", "null"]}
    }
  },
  "$defs": {
    "ontologyTerm": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "ontology", "match_type", "confidence"],
      "properties": {
        "id": {"type": "string"},
        "label": {"type": "string"},
        "ontology": {"type": "string"},
        "iri": {"type": ["string", "null"]},
        "match_type": {
          "type": "string",
          "enum": ["exact_label", "synonym", "fuzzy", "unresolved", "ambiguous"]
        },
        "confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0},
        "candidates": {
          "type": ["array", "null"],
          "items": {"type": "object"}
        }
      }
    },
    "ontologyTermOrNull": {
      "oneOf": [
        {"type": "null"},
        {"$ref": "#/$defs/ontologyTerm"}
      ]
    }
  }
}
